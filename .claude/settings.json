{
  "permissions": {
    "allow": [
      "Bash(python:*)",
      "Bash(pip install:*)",
      "Bash(pip freeze)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(gcloud run deploy:*)",
      "Bash(gcloud run services describe:*)",
      "Bash(gcloud logging read:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(*.session)"
    ]
  }
}
