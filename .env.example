# Copy this file to .env and fill in your values for local testing.
# Never commit .env to git.

TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash_from_my_telegram_org
TELEGRAM_SESSION_STRING=your_session_string_from_auth_py

# --- Channels (multi-channel, unlimited) ---
# Comma-separated. @usernames or numeric ids (e.g. -1001234567890) both work.
SOURCE_CHANNELS=@ukraine_channel_a,@ukraine_channel_b,@ukraine_channel_c

# Choose ONE destination style:
#  (a) Paired 1:1 — same count as SOURCE_CHANNELS, matched by position:
# DEST_CHANNELS=@persian_a,@persian_b,@persian_c
#  (b) Single shared destination — ALL sources post here:
DEST_CHANNEL=@your_persian_channel_username

# Legacy single-source still works too:
# SOURCE_CHANNEL=@ukraine_channel_username

# Set DEBUG_MODE=true to read and filter messages locally without translating or posting.
# TELEGRAM_BOT_TOKEN, DEST_CHANNEL(S), and GOOGLE_CLOUD_PROJECT are not required in debug mode.
DEBUG_MODE=false

TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Optional: Telegram user id for admin commands and error DMs.
# ADMIN_ID=123456789
