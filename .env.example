# Copy this file to .env and fill in your values for local testing.
# Never commit .env to git.

TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash_from_my_telegram_org
TELEGRAM_SESSION_STRING=your_session_string_from_auth_py

# --- Channels (multi-channel, unlimited) ---
# Comma-separated. @usernames or numeric ids (e.g. -1001234567890) both work.
SOURCE_CHANNELS=@ukraine_channel_a,@ukraine_channel_b,@ukraine_channel_c

# Choose ONE destination style:
#  (a) Paired 1:1 — same count as SOURCE_CHANNELS, matched by position:
# DEST_CHANNELS=@persian_a,@persian_b,@persian_c
#  (b) Single shared destination — ALL sources post here:
DEST_CHANNEL=@your_persian_channel_username

# --- Azerbaijani (optional, parallel to Persian) ---
# Same rules as the Persian destinations above: one shared DEST_CHANNEL_AZ for
# all sources, or DEST_CHANNELS_AZ paired 1:1 by position with SOURCE_CHANNELS.
# Leave both unset to run Persian-only.
# DEST_CHANNEL_AZ=@your_azerbaijani_channel_username
# DEST_CHANNELS_AZ=@azerbaijani_a,@azerbaijani_b,@azerbaijani_c

# Legacy single-source still works too:
# SOURCE_CHANNEL=@ukraine_channel_username

# Set DEBUG_MODE=true to read and filter messages locally without translating or posting.
# TELEGRAM_BOT_TOKEN, DEST_CHANNEL(S), and GOOGLE_CLOUD_PROJECT are not required in debug mode.
DEBUG_MODE=false

TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Recommended: GCS bucket for the missed-message catch-up marker (last_seen.json).
# The runtime service account needs roles/storage.objectAdmin on it. If unset, the
# bot still runs but won't catch up on posts made while it was down.
# STATE_BUCKET=your-state-bucket-name

# Optional: Telegram user id for admin commands and error DMs.
# ADMIN_ID=123456789

# Optional: recovering a 👉 apply link the source adds via a later edit.
# A fresh, link-less post is re-fetched every LINK_REFETCH_DELAY_SECONDS (poll
# interval) up to LINK_REFETCH_MAX_WAIT_SECONDS total. If the link never shows
# up, the post is skipped and the admin gets one alert. DELAY=0 disables waiting.
# LINK_REFETCH_DELAY_SECONDS=45
# LINK_REFETCH_MAX_WAIT_SECONDS=300
